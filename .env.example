# Variáveis de ambiente Astro
# Copie este arquivo para .env e preencha com os valores reais

# URL do site em produção (usado em SEO e sitemap)
SITE_URL=https://meusite.com

# Nome do site (aparece no título das páginas)
SITE_NAME=MeuSite

# API Key (se necessário)
# PUBLIC_API_KEY=sua_chave_aqui

# Para vars públicas (acessíveis no browser), use o prefixo PUBLIC_
# Para vars privadas (apenas no servidor), não use prefixo
