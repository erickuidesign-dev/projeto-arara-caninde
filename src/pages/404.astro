---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Página não encontrada"
  description="A página que você procura não existe."
  noIndex={true}
  navTransparent={false}
>
  <div
    class="flex-center flex-col min-h-screen text-center"
    style="gap: var(--space-6); padding: var(--space-8); padding-top: calc(var(--navbar-height) + var(--space-8));"
  >
    <div style="font-size: 5rem; line-height: 1;">🚀</div>
    <h1 style="font-size: var(--text-6xl); font-weight: var(--font-black);" class="text-gradient">404</h1>
    <h2>Página não encontrada</h2>
    <p class="text-muted" style="max-width: 400px;">
      A página que você está procurando não existe ou foi movida para outro endereço.
    </p>
    <div class="flex gap-4 flex-wrap justify-center">
      <a href="/"        class="btn btn-primary btn-lg">← Voltar ao início</a>
      <a href="/contato" class="btn btn-secondary btn-lg">Falar com suporte</a>
    </div>
  </div>
</LandingLayout>
