---
/**
 * FAQ.astro — Seção de perguntas frequentes
 * Interatividade (toggle) é gerenciada pelo script no LandingLayout
 */
interface FAQItem {
  question: string;
  answer:   string;
}

interface Props {
  eyebrow?:  string;
  title?:    string;
  subtitle?: string;
  items?:    FAQItem[];
}

const defaultItems: FAQItem[] = [
  {
    question: 'Como funciona o período de testes?',
    answer:   'Você pode usar o plano gratuito por tempo ilimitado, sem precisar de cartão de crédito. Para recursos avançados, oferecemos um trial de 14 dias do plano Pro.',
  },
  {
    question: 'Posso cancelar a qualquer momento?',
    answer:   'Sim. Não existe fidelidade ou multa de cancelamento. Basta cancelar na sua área de conta e você não será cobrado no próximo ciclo.',
  },
  {
    question: 'Quais formas de pagamento são aceitas?',
    answer:   'Aceitamos cartões de crédito (Visa, Mastercard, Amex), PIX e boleto bancário. Para planos Enterprise, também oferecemos faturamento.',
  },
  {
    question: 'Meus dados estão seguros?',
    answer:   'Sim. Usamos criptografia AES-256 em repouso e TLS 1.3 em trânsito. Somos conformes com LGPD e GDPR. Backups automáticos diários com retenção de 30 dias.',
  },
  {
    question: 'Existe API disponível?',
    answer:   'Sim. Temos uma API REST completa documentada. Planos Pro e Enterprise têm acesso ilimitado. O plano Starter tem limite de 1000 requisições/mês.',
  },
  {
    question: 'Como funciona o suporte?',
    answer:   'Oferecemos suporte via e-mail para todos os planos. O plano Pro inclui suporte via chat (horário comercial) e o Enterprise tem suporte dedicado 24/7 com SLA garantido.',
  },
];

const {
  eyebrow  = '❓ Dúvidas',
  title    = 'Perguntas frequentes',
  subtitle = 'Não encontrou sua resposta? Entre em contato.',
  items    = defaultItems,
} = Astro.props;
---

<section class="section" id="faq">
  <div class="container-md">
    <!-- Header -->
    <div class="section-header">
      <div class="section-eyebrow">
        <span class="badge badge-primary">{eyebrow}</span>
      </div>
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>

    <!-- Accordion -->
    <div>
      {items.map((item) => (
        <div class="faq-item">
          <button class="faq-question" type="button" aria-expanded="false">
            {item.question}
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            {item.answer}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
